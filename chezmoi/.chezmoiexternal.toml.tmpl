# -*- mode: conf-toml; -*-

{{ if .use_emacs }}
[".config/emacs"]
    type = "git-repo"
    url = "https://github.com/doomemacs/doomemacs.git"
    clone.args = [ "--depth",  "1" ]

[".config/doom"]
    type = "git-repo"
    url = "https://github.com/gueckmooh/doom"
    refreshPeriod = "168h"
{{ end }}

{{ if .work_profile }}
[".config/mwdoom"]
    type = "git-repo"
    url = "git@insidelabs-git.mathworks.com:polyspace/tools/mwdoom.git"
    refreshPeriod = "168h"
{{ end }}

[".config/tmux/plugins/tpm"]
    type = "git-repo"
    url = "https://github.com/tmux-plugins/tpm.git"
    refreshPeriod = "168h"

[".config/kitty/kitty-themes"]
    type = "git-repo"
    url = "https://github.com/dexpota/kitty-themes.git"
    refreshPeriod = "168h"
